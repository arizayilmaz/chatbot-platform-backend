SPRING_APPLICATION_NAME=chatbot-platform

# PostgreSQL
POSTGRES_DB=chatbot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
DB_URL=jdbc:postgresql://localhost:5432/chatbot
DB_USER=postgres
DB_PASS=password

# RabbitMQ
RABBIT_HOST=localhost
RABBIT_PORT=5672
RABBIT_USER=guest
RABBIT_PASS=guest

# Flyway
FLYWAY_ENABLED=true

# LLM
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.2:3b
LLM_TIMEOUT_SECONDS=60

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-with-at-least-32-bytes
JWT_EXPIRES_MINUTES=3600

# Events
EVENTS_EXCHANGE=chat.events
EVENTS_QUEUE=chat.audit

# Outbox
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_ATTEMPTS=5
OUTBOX_INITIAL_DELAY=10
OUTBOX_POLL_INTERVAL_MS=5000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,http://127.0.0.1:5173,http://127.0.0.1:4173
